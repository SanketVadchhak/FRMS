  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.4.5",
    "zod": "^3.23.8"
  }
}
