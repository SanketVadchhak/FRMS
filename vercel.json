{
  "version": 2,
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 60,
      "includeFiles": "{node_modules/.prisma,apps/api/prisma,packages/shared,node_modules/@frms/shared}/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
